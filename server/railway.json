{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "docker",
    "dockerfile": "Dockerfile"
  },
  "deploy": {
    "startCommand": "node index.js",
    "restartPolicyMaxRetries": 5,
    "numReplicas": 1,
    "healthchecks": {
      "enabled": true,
      "endpoint": "/health",
      "interval": 10
    }
  }
}
