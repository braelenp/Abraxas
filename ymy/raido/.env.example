# Environment Configuration

# Solana Network (mainnet-beta | devnet | testnet | localhost)
VITE_SOLANA_NETWORK=devnet

# RPC Endpoint (optional, uses default if not specified)
VITE_SOLANA_RPC_ENDPOINT=https://api.devnet.solana.com

# Optional: Helius RPC (high performance)
# VITE_SOLANA_RPC_ENDPOINT=https://devnet.helius-rpc.com?api-key=YOUR_KEY

# Wallet Adapter Configuration
VITE_WALLET_ADAPTER_NETWORK=devnet

# Optional: Jupiter API
VITE_JUPITER_API=https://quote-api.jup.ag/v6

# Optional: DexScreener API
VITE_DEXSCREENER_API=https://api.dexscreener.com/latest/dex

# Optional: Pool data
VITE_RAYDIUM_API=https://api.raydium.io/v2

# App Configuration
VITE_APP_NAME=Raido
VITE_APP_DESCRIPTION=The Swift Provider - Liquidity Engine on Solana
